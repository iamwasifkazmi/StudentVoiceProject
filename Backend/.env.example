# Pooled connection (PgBouncer) — use for the running app / Prisma Client
# Replace [YOUR-PASSWORD] and URL-encode special characters in the password ($ % / + etc.)
DATABASE_URL="postgresql://postgres.cfxkcvvsemfifeyijdum:[YOUR-PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — required for Prisma Migrate (bypasses pooler)
DIRECT_URL="postgresql://postgres.cfxkcvvsemfifeyijdum:[YOUR-PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres?sslmode=require"

# Generate with: openssl rand -base64 32
JWT_SECRET="change-me-access-token-secret"

PORT=3000
NODE_ENV=development

# Comma-separated origins for CORS (optional; defaults to * for mobile dev)
# CORS_ORIGIN=http://localhost:8081
