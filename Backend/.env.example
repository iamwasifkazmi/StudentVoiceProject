# --- Supabase / Postgres (copy values from Supabase → Project Settings → Database) ---
#
# DATABASE_URL: use the **Transaction pooler** (or “Pooler” URI), port **6543**.
#   Username is usually `postgres.[PROJECT_REF]` (not plain `postgres`).
#   Append `?pgbouncer=true` for Prisma + transaction pooler.
#
# DIRECT_URL: use the **Direct connection** string — host must be `db.[PROJECT_REF].supabase.co`
#   on port **5432** with user `postgres`. Do NOT set DIRECT_URL to the pooler hostname;
#   Prisma Migrate and introspection need a real Postgres connection.
#
# URL-encode special characters in the password ($ % / + @ # etc.).

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

DIRECT_URL="postgresql://postgres:[URL-ENCODED-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Generate with: openssl rand -base64 32
JWT_SECRET="change-me-access-token-secret"

PORT=3000
NODE_ENV=development

# Comma-separated origins for CORS (optional; defaults to * for mobile dev)
# CORS_ORIGIN=http://localhost:8081
