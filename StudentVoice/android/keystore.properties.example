# Copy to keystore.properties in this folder (android/) and fill in passwords.
# Do not commit keystore.properties or *.keystore.
#
# Generate keystore (one time), from android/app/:
#   keytool -genkeypair -v -keystore studentvoice-release.keystore -alias studentvoice \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass YOUR_STORE_PASSWORD -keypass YOUR_KEY_PASSWORD \
#     -dname "CN=Student Voice, OU=Testing, O=StudentVoice, L=Local, ST=NA, C=US"
#
storeFile=studentvoice-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=studentvoice
keyPassword=YOUR_KEY_PASSWORD
